{
  "expo": {
    "name": "ClearWelth",
    "slug": "clearwelth",
    "scheme": "clearwelth",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D2040"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clearwelth.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "usesCleartextTraffic": true,
      "package": "com.clearwelth.app",
      "icon": "./assets/icon.png"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "df861b24-c1f9-49d6-a6a1-5255c267e6a8"
      }
    }
  }
}
